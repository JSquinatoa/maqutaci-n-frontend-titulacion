# ========================================
# Odonto Estetic Cloud — Variables de entorno
# ========================================
# Cuando el backend Quarkus esté listo, descomenta y configura la URL:
# VITE_API_URL=http://localhost:8080/api

# Mientras tanto, la app funciona en modo mock (sin backend).
# Al configurar VITE_API_URL, TODOS los servicios se conectarán
# automáticamente al backend real.
